# ==================== 过滤规则 ====================
FILTER_RULES = {
    # 过滤科创板(688开头)
    "exclude_code_prefix": ["688"],
    # 过滤北交所(8开头)
    "exclude_bj": True,
    # 过滤ST股
    "exclude_st": True,
    # 过滤停牌
    "exclude_suspended": True,
    # 过滤涨停（涨幅>=8%，涨停无法买进）
    "exclude_limit_up": True,  # 过滤涨停股
    "limit_up_threshold": 8.0,  # 涨停阈值（涨幅>=8%视为涨停）
    # 过滤跌停
    "exclude_limit_down": True,
    # 成交额最低限制（万元）
    "min_turnover": 3000,  # 3000万
    # 涨幅范围（要求强劲但未涨停）
    "change_pct_range": {"min": 0, "max": 9.9},  # 0%-9.9%，扩大范围以选出更多股票
    # 接近涨停惩罚（涨幅>8%降权）- 已废除，涨停直接过滤
    "near_limit_penalty": False,  # 关闭降权
    "near_limit_threshold": 9.5,
    # 净流入配置（模拟/简化版）
    "net_inflow_check": False,  # 暂时关闭净流入筛选
    "net_inflow_days": [5, 20],  # 5日、20日净流入检测
}

